# ── MongoDB Atlas ──────────────────────────────────────────────
# Get this from: MongoDB Atlas → Cluster → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/edusys_prod?retryWrites=true&w=majority

# ── JWT ────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── CORS ───────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── First-run Admin Seed (only used when running: node seed.js) ─
ADMIN_NAME=School Administrator
ADMIN_EMAIL=admin@yourschool.edu
ADMIN_PASSWORD=ChangeThisImmediately!
